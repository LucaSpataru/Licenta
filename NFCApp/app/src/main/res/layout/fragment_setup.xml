<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setup"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:paddingTop="16dp"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Server ESP32"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:textAllCaps="true"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="URL ESP32:"
                android:textSize="13sp"
                android:textColor="#616161" />

            <EditText
                android:id="@+id/etEsp32Url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="http://192.168.0.177"
                android:inputType="textUri"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/btnSaveUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Salveaza si testeaza conexiunea"
                android:layout_marginTop="8dp"
                android:backgroundTint="#1976D2"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/urlTestResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:paddingTop="8dp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cheie criptografica"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:textAllCaps="true"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp">

            <TextView
                android:id="@+id/keyStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: -"
                android:textSize="14sp"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/keyDetailsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#757575"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/btnRegenerateKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Regenereaza cheia"
                android:layout_marginTop="12dp"
                android:backgroundTint="#FB8C00"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Regenerarea cheii necesita reinrolarea telefonului la ESP32"
                android:textSize="11sp"
                android:paddingTop="6dp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inrolare la ESP32"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:textAllCaps="true"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp">

            <TextView
                android:id="@+id/enrollStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Verifica status server..."
                android:textSize="14sp"
                android:textColor="#212121" />

            <Button
                android:id="@+id/btnEnroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inroleaza acest telefon"
                android:layout_marginTop="12dp"
                android:backgroundTint="#43A047"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/enrollResultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#616161"
                android:paddingTop="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inrolarea se face cand fereastra e deschisa"
                android:textSize="11sp"
                android:paddingTop="6dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>